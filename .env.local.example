# Release signing config — DO NOT commit
# Copy this file to .env.local and fill in real values, then run:
#   pwsh scripts/setup-release-signing.ps1
#
# The script writes android/key.properties + sets 4 GitHub Actions secrets.

# Path to the release keystore, relative to repo root
KEYSTORE_PATH=android/app/release.keystore

# Alias used in keytool -genkey
KEY_ALIAS=duoduo-deep

# Keystore password (-storepass)
KEYSTORE_PASSWORD=your_keystore_password

# Key password (-keypass), often same as KEYSTORE_PASSWORD
KEY_PASSWORD=your_key_password
